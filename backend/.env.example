# Payoneer Checkout (billing). From the merchant portal: Integration > API access.
PAYONEER_API_USERNAME=
PAYONEER_PAYMENT_TOKEN=
PAYONEER_DIVISION=
# Make this up yourself (any long random string) — it's appended to our own
# notificationUrl so we can confirm a notification actually came from a checkout
# we started, since Payoneer Checkout has no signature/HMAC scheme.
PAYONEER_NOTIFICATION_TOKEN=
# Defaults to the sandbox host; switch to the live one once Payoneer confirms it
# for your account.
# PAYONEER_API_BASE_URL=https://api.sandbox.oscato.com
FRONTEND_URL=http://localhost:5173

# Real email delivery (signup/password-reset codes). Leave unset locally — emails
# print to the console instead. Set RESEND_API_KEY in Railway once you have one.
# RESEND_API_KEY=re_...
# Until your sending domain is verified in Resend, override this to their test
# sender so emails actually deliver: DEFAULT_FROM_EMAIL=onboarding@resend.dev
# DEFAULT_FROM_EMAIL=KnowBeforeYouGo <noreply@knowbeforeyougobahamas.com>

# Production deployment (e.g. Railway) — leave unset for local dev.
# SECRET_KEY=
# DEBUG=False
# ALLOWED_HOSTS=your-app.up.railway.app
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# DATABASE_URL is injected automatically by Railway's Postgres plugin — don't set manually.
